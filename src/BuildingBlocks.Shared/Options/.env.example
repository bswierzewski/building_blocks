# =============================================================================
# Authentication Options - .NET Configuration Format
# =============================================================================
# This file shows example environment variables for authentication providers.
# Copy this file to .env and fill in your actual values.
#
# Note: In .NET, use double underscore (__) to represent nested configuration.
# Example: Supabase__Authority maps to configuration section "Supabase:Authority"
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Authentication
# -----------------------------------------------------------------------------
# Authority: Your Supabase project URL (e.g., https://xxxxx.supabase.co)
# JwtSecret: JWT secret key from Supabase project settings (required for HS256)
# Audience: Optional - typically "authenticated" for Supabase
# -----------------------------------------------------------------------------
Supabase__Authority=https://your-project.supabase.co
Supabase__JwtSecret=your-supabase-jwt-secret-key-here
Supabase__Audience=authenticated

# -----------------------------------------------------------------------------
# Auth0 Authentication
# -----------------------------------------------------------------------------
# Authority: Your Auth0 domain (e.g., https://your-tenant.auth0.com/)
# Audience: Your API identifier in Auth0 (required)
# -----------------------------------------------------------------------------
Auth0__Authority=https://your-tenant.auth0.com/
Auth0__Audience=your-auth0-api-identifier

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
# Authority: Your Clerk frontend API URL (e.g., https://your-domain.clerk.accounts.dev)
# Audience: Optional - leave empty to disable audience validation
# -----------------------------------------------------------------------------
Clerk__Authority=https://your-domain.clerk.accounts.dev
Clerk__Audience=
