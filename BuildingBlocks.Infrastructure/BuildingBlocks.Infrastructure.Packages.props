    <!-- Entity Framework Core -->
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.5" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Relational" Version="10.0.5" />

    <!-- Npgsql -->
    <PackageVersion Include="Npgsql" Version="10.0.0" />
    <PackageVersion Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.0" />

    <!-- Serilog -->
    <PackageVersion Include="Serilog.AspNetCore" Version="10.0.0" />
    <PackageVersion Include="Serilog.Extensions.Hosting" Version="10.0.0" />
    <PackageVersion Include="Serilog.Enrichers.Environment" Version="3.0.1" />
    <PackageVersion Include="Serilog.Enrichers.Span" Version="3.1.0" />
    <PackageVersion Include="Serilog.Formatting.Compact" Version="3.0.0" />
    <PackageVersion Include="Serilog.Sinks.Async" Version="2.1.0" />
    <PackageVersion Include="Serilog.Sinks.Console" Version="6.1.1" />
    <PackageVersion Include="Serilog.Sinks.File" Version="7.0.0" />
    <PackageVersion Include="Serilog.Sinks.OpenTelemetry" Version="4.2.0" />

    <!-- WolverineFx -->
    <PackageVersion Include="WolverineFx" Version="5.30.0" />
    <PackageVersion Include="WolverineFx.EntityFrameworkCore" Version="5.29.0" />
    <PackageVersion Include="WolverineFx.FluentValidation" Version="5.29.0" />
    <PackageVersion Include="WolverineFx.Http" Version="5.29.0" />
    <PackageVersion Include="WolverineFx.Http.FluentValidation" Version="5.29.0" />
    <PackageVersion Include="WolverineFx.Postgresql" Version="5.29.0" />
  </ItemGroup>
</Project>
